# Copy to .env and fill in. .env is gitignored.

# --- Project under test ---
# Absolute path to the product source. Skills default here when no path is passed.
PROJECT_UNDER_TEST=

# Override for where automated tests are written. If unset, `test-auto`
# writes into `./automation` in this workspace (see automation/README.md).
# Set this if your team already maintains a test project elsewhere.
TEST_PROJECT_PATH=

# Where `test-docs` writes manual test cases. Default: `test-cases/` in this
# workspace. Override if your team uses a different location (e.g. inside the
# product repo at `<repo>/docs/test-cases`).
TEST_CASES_DIR=

# --- Azure DevOps ---
AZDO_PAT=
AZDO_ORG=
AZDO_PROJECT=

# --- Jira ---
JIRA_TOKEN=
JIRA_BASE_URL=
JIRA_PROJECT=

# --- GitHub ---
GH_TOKEN=

# --- App-under-test runtime endpoints ---
APP_BASE_URL=
TEST_USER=
TEST_PASSWORD=

API_BASE_URL=
API_TOKEN=
